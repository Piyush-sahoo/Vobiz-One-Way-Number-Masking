# Copy this file to .env and fill in your own values. .env is gitignored.

# ---- Vobiz API credentials (https://console.vobiz.ai) ----
VOBIZ_AUTH_ID=MA_XXXXXXXXXXXXXXXX
VOBIZ_AUTH_TOKEN=your_auth_token_here
VOBIZ_API_BASE=https://api.vobiz.ai/api/v1

# ---- Public HTTPS URL of THIS backend (ngrok / cloudflared tunnel) ----
PUBLIC_BASE_URL=https://your-tunnel.trycloudflare.com

# ---- One-way mappings: masking:destination pairs (E.164, no '+'), comma-separated ----
# Each masking number forwards every caller to its destination.
ONE_WAY_MAPPINGS=919000000001:919876511111,919000000002:919876522222
